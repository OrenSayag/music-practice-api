# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/music_practice

# Auth.js
AUTH_SECRET=              # openssl rand -base64 32
AUTH_URL=http://localhost:5178  # Frontend origin (UI proxies /api to the API server)
AUTH_RESEND_KEY=          # Resend API key
EMAIL_FROM=noreply@example.com
SESSION_MAX_AGE_SECONDS=  # Default to 30 days

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
LOG_LEVEL=debug

# AI
AI_PROVIDER=openai                # openai | anthropic
AI_API_KEY=                       # API key for the selected provider
AI_MODEL=gpt-4o-mini             # Model identifier (e.g. gpt-4o-mini, claude-sonnet-4-20250514)
PRACTICE_PLAN_CHAT_SYSTEM_PROMPT_FILE_PATH=./prompts/practice-plan-chat.md

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=recordings
S3_REGION=us-east-1

# Rate Limiting (optional)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
# MAGIC_LINK_RATE_LIMIT_WINDOW_MS=900000
# MAGIC_LINK_RATE_LIMIT_MAX_REQUESTS=5
